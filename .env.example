# Copy this file to .env and fill in real values before running the server.

# Port the server listens on
PORT=3000

# Secret key required to access /api/admin/* routes and the admin.html dashboard.
# Make this long and random — anyone with this key can see registrations and
# rewrite the leaderboard, schedule, and news.
ADMIN_KEY=change-this-to-a-long-random-secret

# Razorpay keys — get these from https://dashboard.razorpay.com/app/keys
# Leave blank to keep paid-entry tournaments disabled (free tournaments still work).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Secret used to sign player login sessions (JWTs). Make this long and random —
# generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Postgres connection string for storing registrations permanently.
# Leave blank to use a local JSON file instead (fine for testing, but data can
# be lost on some hosting platforms when the service restarts or redeploys).
# Get a free one from https://neon.tech (no card, no expiry on the free tier).
# Looks like: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=
