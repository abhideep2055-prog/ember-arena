# Copy this file to .env and fill in real values before running the server.

# Port the server listens on
PORT=3000

# Secret key required to access /api/admin/* routes and the admin.html dashboard.
# Make this long and random — anyone with this key can see registrations and
# rewrite the leaderboard, schedule, and news.
ADMIN_KEY=change-this-to-a-long-random-secret

# Razorpay keys — get these from https://dashboard.razorpay.com/app/keys
# Leave blank to keep paid-entry tournaments disabled (free tournaments still work).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
